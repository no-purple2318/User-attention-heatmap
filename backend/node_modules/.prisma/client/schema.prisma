datasource db {
  provider = "sqlite"
  url      = "file:../../dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  role         String    @default("USER")
  createdAt    DateTime  @default(now())
  sessions     Session[]
}

model Session {
  id        String     @id @default(uuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id])
  url       String
  startTime DateTime   @default(now())
  endTime   DateTime?
  events    EventLog[]
}

model EventLog {
  id        String   @id @default(uuid())
  sessionId String
  session   Session  @relation(fields: [sessionId], references: [id])
  timestamp DateTime
  type      String // "mouse", "scroll", "eye"
  x         Float
  y         Float
}
