{
    "manifest_version": 3,
    "name": "User Attention Heatmap Tracker2",
    "version": "1.0",
    "description": "Tracks real-time cursor movements, scroll distances, and eye-gazing for heatmap generation.",
    "permissions": [
        "storage",
        "activeTab",
        "scripting",
        "tabs"
    ],
    "host_permissions": [
        "https://*/*",
        "http://localhost:3001/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "gaze.js",
                "content.js"
            ],
            "run_at": "document_idle"
        }
    ],
    "action": {
        "default_popup": "popup.html"
    }
}